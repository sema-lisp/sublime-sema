%YAML 1.2
---
# Sema syntax for Sublime Text (native .sublime-syntax).
# Scope names mirror vscode-sema's TextMate grammar so color schemes theme
# both editors identically. Keep in sync with:
#   https://github.com/sema-lisp/vscode-sema/blob/main/syntaxes/sema.tmLanguage.json
name: Sema
scope: source.sema
version: 2

file_extensions:
  - sema

first_line_match: '^#!.*\bsema\b'

contexts:
  main:
    - include: block-comment
    - include: line-comment
    - include: string
    - include: quoted-expression
    - include: definition
    - include: special-form
    - include: threading-macro
    - include: builtin
    - include: operator
    - include: keyword-literal
    - include: character
    - include: boolean
    - include: nil
    - include: number
    - include: paren

  # ---------------------------------------------------------------------
  # COMMENTS
  # ---------------------------------------------------------------------
  block-comment:
    - match: '#\|'
      scope: punctuation.definition.comment.begin.sema
      push: block-comment-body

  block-comment-body:
    - meta_scope: comment.block.sema
    - match: '#\|'
      push: block-comment-body
    - match: '\|#'
      scope: punctuation.definition.comment.end.sema
      pop: true

  line-comment:
    - match: ';'
      scope: punctuation.definition.comment.sema
      push:
        - meta_scope: comment.line.semicolon.sema
        - match: '$\n?'
          pop: true

  # ---------------------------------------------------------------------
  # STRINGS
  # ---------------------------------------------------------------------
  string:
    - match: '"'
      scope: punctuation.definition.string.begin.sema
      push:
        - meta_scope: string.quoted.double.sema
        - match: '\\(?:[\\"nrt0]|x[0-9a-fA-F]+;|u[0-9a-fA-F]{4}|U[0-9a-fA-F]{8})'
          scope: constant.character.escape.sema
        - match: '"'
          scope: punctuation.definition.string.end.sema
          pop: true

  # ---------------------------------------------------------------------
  # QUOTE OPERATORS
  # ---------------------------------------------------------------------
  quoted-expression:
    - match: '(?<=[\s(\[{])''|^'''
      scope: keyword.operator.quote.sema
    - match: '(?<=[\s(\[{])`|^`'
      scope: keyword.operator.quasiquote.sema
    - match: '(?<=[\s(\[{]),@|^,@'
      scope: keyword.operator.unquote-splicing.sema
    - match: '(?<=[\s(\[{]),|^,'
      scope: keyword.operator.unquote.sema

  # ---------------------------------------------------------------------
  # DEFINITIONS
  # ---------------------------------------------------------------------
  definition:
    # (define (name args...) ...) — must come before the simple-define rule
    - match: '(\()\s*(define)\s+(\()\s*([\w!$%&*+\-./:<=>?@^~][\w!$%&*+\-./:<=>?@^~0-9]*)'
      captures:
        1: punctuation.paren.open.sema
        2: keyword.control.definition.sema
        3: punctuation.paren.open.sema
        4: entity.name.function.sema
    # (define name ...)
    - match: '(\()\s*(define)\s+([\w!$%&*+\-./:<=>?@^~][\w!$%&*+\-./:<=>?@^~0-9]*)'
      captures:
        1: punctuation.paren.open.sema
        2: keyword.control.definition.sema
        3: variable.other.sema
    # (defun|defmacro|... name ...)
    - match: '(\()\s*(defun|defmacro|defmulti|defmethod|defagent|deftool|defn|def|defworkflow|define-record-type)\s+([\w!$%&*+\-./:<=>?@^~][\w!$%&*+\-./:<=>?@^~0-9]*)'
      captures:
        1: punctuation.paren.open.sema
        2: keyword.control.definition.sema
        3: entity.name.function.sema
    # (set! name value)
    - match: '(\()\s*(set!)\s+([\w!$%&*+\-./:<=>?@^~][\w!$%&*+\-./:<=>?@^~0-9]*)'
      captures:
        1: punctuation.paren.open.sema
        2: keyword.control.sema
        3: variable.other.sema

  # ---------------------------------------------------------------------
  # SPECIAL FORMS
  # ---------------------------------------------------------------------
  special-form:
    - match: '(?<=[\s(\[{])(?:define|async|await|defn|def|progn|dotimes|for-range|with-retry|with-session|with-span|with-stream|defworkflow|defun|lambda|fn|if|if-let|cond|case|when|when-let|unless|let\*?|letrec|begin|do|while|and|or|set!|quote|quasiquote|unquote-splicing|unquote|define-record-type|defmacro|defmethod|defmulti|defagent|deftool|try|catch|throw|import|module|export|load|delay|force|eval|macroexpand|else|prompt|message|match\*|match)(?=[\s)\]}]|$)'
      scope: keyword.control.sema

  # ---------------------------------------------------------------------
  # OPERATORS
  # ---------------------------------------------------------------------
  operator:
    - match: '(?<=[\s(\[{])(?:\+|\*|/|%|>=|<=|>(?!=)|<(?!=)|=|-|eqv\?)(?=[\s)\]}]|$)'
      scope: keyword.operator.arithmetic.sema

  threading-macro:
    - match: '(?<=[\s(\[{])(?:->>?|as->|some->)(?=[\s)\]}]|$)'
      scope: keyword.operator.threading.sema

  # ---------------------------------------------------------------------
  # BUILTIN FUNCTIONS
  # ---------------------------------------------------------------------
  builtin:
    # Higher-order and core functions
    - match: '(?<=[\s(\[{])(?:map|filter|foldl|foldr|reduce|for-each|apply|gensym|not|error|assert|assert=|deep-merge|get-in|assoc-in|update-in|tap|spy|pprint|retry|time)(?=[\s)\]}]|$)'
      scope: support.function.sema
    # List functions
    - match: '(?<=[\s(\[{])(?:list|cons|car|cdr|first|rest|nth|append|reverse|length|null\?|list\?|member|vector|sort|sort-by|take|drop|zip|flatten|range|make-list|flat-map|take-while|drop-while|every|any|partition|last|iota)(?=[\s)\]}]|$)'
      scope: support.function.sema
    # ca*r/cd*r variants
    - match: '(?<=[\s(\[{])(?:caar|cadr|cdar|cddr|caaar|caadr|cadar|caddr|cdaar|cdadr|cddar|cdddr)(?=[\s)\]}]|$)'
      scope: support.function.sema
    # list/* namespaced functions
    - match: '(?<=[\s(\[{])(?:list/chunk|list/dedupe|list/drop-while|list/group-by|list/index-of|list/interleave|list/max|list/min|list/pick|list/repeat|list/shuffle|list/split-at|list/sum|list/take-while|list/unique|list->bytevector|list->string|list->vector|list/avg|list/cross-join|list/diff|list/duplicates|list/find|list/intersect|list/join|list/key-by|list/median|list/mode|list/pad|list/page|list/pluck|list/reject|list/sliding|list/sole|list/times)(?=[\s)\]}]|$)'
      scope: support.function.sema
    # Additional list functions
    - match: '(?<=[\s(\[{])(?:assoc|assq|assv|flatten-deep|frequencies|interpose|vector->list)(?=[\s)\]}]|$)'
      scope: support.function.sema
    # Map functions
    - match: '(?<=[\s(\[{])(?:hash-map|get|dissoc|merge|keys|vals|contains\?|count|empty\?)(?=[\s)\]}]|$)'
      scope: support.function.sema
    # map/* namespaced functions
    - match: '(?<=[\s(\[{])(?:map/entries|map/filter|map/from-entries|map/map-keys|map/map-vals|map/select-keys|map/update|map/except|map/sort-keys|map/zip)(?=[\s)\]}]|$)'
      scope: support.function.sema
    # hashmap/* functions
    - match: '(?<=[\s(\[{])(?:hashmap/new|hashmap/get|hashmap/assoc|hashmap/keys|hashmap/contains\?|hashmap/to-map)(?=[\s)\]}]|$)'
      scope: support.function.sema
    # String functions
    - match: '(?<=[\s(\[{])(?:string-append|string/join|string/split|string/trim|string/upper|string/lower|string/replace|string/contains\?|string/starts-with\?|string/ends-with\?|string/capitalize|string/empty\?|string/index-of|string/reverse|string/repeat|string/pad-left|string/pad-right|str|substring|string-length|string-ref|string/byte-length|string/chars|string/codepoints|string/foldcase|string/from-codepoints|string/last-index-of|string/map|string/normalize|string/number\?|string/title-case|string/trim-left|string/trim-right|string-ci=\?|string/after|string/after-last|string/before|string/before-last|string/between|string/camel-case|string/chop-end|string/chop-start|string/ensure-end|string/ensure-start|string/headline|string/intern|string/kebab-case|string/pascal-case|string/remove|string/replace-first|string/replace-last|string/snake-case|string/take|string/unwrap|string/words|string/wrap)(?=[\s)\]}]|$)'
      scope: support.function.sema
    # String conversions
    - match: '(?<=[\s(\[{])(?:string->char|string->float|string->list|string->utf8)(?=[\s)\]}]|$)'
      scope: support.function.sema
    # Char functions
    - match: '(?<=[\s(\[{])(?:char->integer|char->string|integer->char|char-alphabetic\?|char-ci<\?|char-ci<=\?|char-ci=\?|char-ci>\?|char-ci>=\?|char-downcase|char-lower-case\?|char-numeric\?|char-upcase|char-upper-case\?|char-whitespace\?|char<\?|char<=\?|char=\?|char>\?|char>=\?)(?=[\s)\]}]|$)'
      scope: support.function.sema
    # IO and display
    - match: '(?<=[\s(\[{])(?:display|print|println|newline|format|read|read-line|read-many|print-error|println-error|read-stdin)(?=[\s)\]}]|$)'
      scope: support.function.sema
    # Type predicates
    - match: '(?<=[\s(\[{])(?:number\?|string\?|symbol\?|pair\?|boolean\?|procedure\?|integer\?|float\?|keyword\?|nil\?|fn\?|map\?|record\?|equal\?|eq\?|zero\?|positive\?|negative\?|even\?|odd\?|type|bool\?|bytevector\?|char\?|vector\?|promise\?|agent\?|conversation\?|message\?|prompt\?|tool\?|promise-forced\?)(?=[\s)\]}]|$)'
      scope: support.function.sema
    # Type conversions
    - match: '(?<=[\s(\[{])(?:string->number|number->string|string->symbol|symbol->string|string->keyword|keyword->string)(?=[\s)\]}]|$)'
      scope: support.function.sema
    # Math functions and constants
    - match: '(?<=[\s(\[{])(?:abs|min|max|round|floor|ceiling|sqrt|expt|pow|log|sin|cos|ceil|int|float|truncate|mod|modulo|math/remainder|math/gcd|math/lcm|math/pow|math/tan|math/random|math/random-int|math/clamp|math/sign|math/exp|math/log10|math/log2|math/acos|math/asin|math/atan|math/atan2|math/cosh|math/degrees->radians|math/infinite\?|math/lerp|math/map-range|math/nan\?|math/quotient|math/radians->degrees|math/sinh|math/tanh|math/infinity|math/nan|pi|e)(?=[\s)\]}]|$)'
      scope: support.function.sema
    # File functions
    - match: '(?<=[\s(\[{])(?:file/read|file/write|file/exists\?|file/delete|file/list|file/append|file/rename|file/mkdir|file/info|file/read-lines|file/write-lines|file/is-directory\?|file/is-file\?|file/copy|file/fold-lines|file/for-each-line|file/is-symlink\?|file/glob|file/read-bytes|file/write-bytes)(?=[\s)\]}]|$)'
      scope: support.function.sema
    # Path functions
    - match: '(?<=[\s(\[{])(?:path/absolute|path/absolute\?|path/basename|path/dir|path/dirname|path/ext|path/extension|path/filename|path/join|path/stem)(?=[\s)\]}]|$)'
      scope: support.function.sema
    # PDF functions
    - match: '(?<=[\s(\[{])(?:pdf/extract-text|pdf/extract-text-pages|pdf/metadata|pdf/page-count)(?=[\s)\]}]|$)'
      scope: support.function.sema
    # JSON and TOML functions
    - match: '(?<=[\s(\[{])(?:json/decode|json/encode|json/encode-pretty|toml/decode|toml/encode)(?=[\s)\]}]|$)'
      scope: support.function.sema
    # HTTP client functions
    - match: '(?<=[\s(\[{])(?:http/get|http/post|http/put|http/delete|http/request)(?=[\s)\]}]|$)'
      scope: support.function.sema
    # HTTP server functions
    - match: '(?<=[\s(\[{])(?:http/serve|http/router|http/router/dispatch|http/file|http/ok|http/created|http/no-content|http/not-found|http/error|http/redirect|http/html|http/text|http/stream|http/stream/send|http/websocket)(?=[\s)\]}]|$)'
      scope: support.function.sema
    # WebSocket functions
    - match: '(?<=[\s(\[{])(?:ws/send|ws/recv|ws/close)(?=[\s)\]}]|$)'
      scope: support.function.sema
    # Regex functions
    - match: '(?<=[\s(\[{])(?:regex/match\?|regex/match|regex/find-all|regex/replace|regex/replace-all|regex/split)(?=[\s)\]}]|$)'
      scope: support.function.sema
    # Crypto and encoding functions
    - match: '(?<=[\s(\[{])(?:uuid/v4|base64/encode|base64/decode|base64/encode-bytes|base64/decode-bytes|hash/md5|hash/sha256|hash/hmac-sha256)(?=[\s)\]}]|$)'
      scope: support.function.sema
    # DateTime functions
    - match: '(?<=[\s(\[{])(?:time/now|time/format|time/parse|time/date-parts|time/add|time/diff|time-ms)(?=[\s)\]}]|$)'
      scope: support.function.sema
    # CSV functions
    - match: '(?<=[\s(\[{])(?:csv/parse|csv/parse-maps|csv/encode)(?=[\s)\]}]|$)'
      scope: support.function.sema
    # Bitwise functions
    - match: '(?<=[\s(\[{])(?:bit/and|bit/or|bit/xor|bit/not|bit/shift-left|bit/shift-right)(?=[\s)\]}]|$)'
      scope: support.function.sema
    # Terminal functions
    - match: '(?<=[\s(\[{])(?:term/style|term/strip|term/rgb|term/spinner-start|term/spinner-stop|term/spinner-update|term/black|term/blue|term/bold|term/cyan|term/dim|term/gray|term/green|term/inverse|term/italic|term/magenta|term/red|term/strikethrough|term/underline|term/white|term/yellow)(?=[\s)\]}]|$)'
      scope: support.function.sema
    # Bytevector functions
    - match: '(?<=[\s(\[{])(?:bytevector|make-bytevector|bytevector-length|bytevector-u8-ref|bytevector-u8-set!|bytevector-copy|bytevector-append|bytevector->list|utf8->string)(?=[\s)\]}]|$)'
      scope: support.function.sema
    # System functions
    - match: '(?<=[\s(\[{])(?:env|shell|exit|sleep|sys/args|sys/cwd|sys/platform|sys/set-env|sys/env-all|sys/arch|sys/elapsed|sys/home-dir|sys/hostname|sys/interactive\?|sys/os|sys/pid|sys/temp-dir|sys/tty|sys/user|sys/which|sys/interner-stats|sys/sema-home)(?=[\s)\]}]|$)'
      scope: support.function.sema
    # Context functions
    - match: '(?<=[\s(\[{])(?:context/get|context/set|context/has\?|context/remove|context/all|context/clear|context/merge|context/with|context/push|context/pop|context/pull|context/stack|context/get-hidden|context/set-hidden|context/has-hidden\?)(?=[\s)\]}]|$)'
      scope: support.function.sema
    # Key-value store functions
    - match: '(?<=[\s(\[{])(?:kv/open|kv/close|kv/get|kv/set|kv/delete|kv/keys)(?=[\s)\]}]|$)'
      scope: support.function.sema
    # Text processing functions
    - match: '(?<=[\s(\[{])(?:text/chunk|text/chunk-by-separator|text/clean-whitespace|text/excerpt|text/normalize-newlines|text/split-sentences|text/strip-html|text/trim-indent|text/truncate|text/word-count)(?=[\s)\]}]|$)'
      scope: support.function.sema
    # Document functions
    - match: '(?<=[\s(\[{])(?:document/create|document/chunk|document/text|document/metadata)(?=[\s)\]}]|$)'
      scope: support.function.sema
    # Log functions
    - match: '(?<=[\s(\[{])(?:log/debug|log/info|log/warn|log/error)(?=[\s)\]}]|$)'
      scope: support.function.sema
    # Prompt template functions
    - match: '(?<=[\s(\[{])(?:prompt/render|prompt/template|prompt/concat|prompt/fill|prompt/slots)(?=[\s)\]}]|$)'
      scope: support.function.sema
    # LLM functions
    - match: '(?<=[\s(\[{])(?:conversation/new|conversation/say|conversation/say-as|conversation/messages|conversation/last-reply|conversation/fork|conversation/add-message|conversation/model|conversation/set-system|conversation/system|conversation/cost|conversation/filter|conversation/map|conversation/token-count|llm/complete|llm/chat|llm/stream|llm/send|llm/extract|llm/extract-from-image|llm/classify|llm/batch|llm/pmap|llm/embed|llm/auto-configure|llm/configure|llm/set-budget|llm/budget-remaining|llm/define-provider|llm/last-usage|llm/session-usage|llm/similarity|llm/clear-budget|llm/configure-embeddings|llm/current-provider|llm/default-provider|llm/list-providers|llm/providers|llm/pricing-status|llm/reset-usage|llm/set-default|llm/set-pricing|llm/compare|llm/summarize|llm/token-count|llm/token-estimate|llm/with-budget|llm/with-cache|llm/with-fallback|llm/with-rate-limit|llm/cache-clear|llm/cache-key|llm/cache-stats|prompt/append|prompt/messages|prompt/set-system|message/role|message/content|message/with-image|agent/run|agent/max-turns|agent/model|agent/name|agent/system|agent/tools)(?=[\s)\]}]|$)'
      scope: support.function.sema
    # Embedding functions
    - match: '(?<=[\s(\[{])(?:embedding/->list|embedding/length|embedding/list->embedding|embedding/ref)(?=[\s)\]}]|$)'
      scope: support.function.sema
    # Vector math functions
    - match: '(?<=[\s(\[{])(?:vector/cosine-similarity|vector/distance|vector/dot-product|vector/normalize)(?=[\s)\]}]|$)'
      scope: support.function.sema
    # Vector store functions
    - match: '(?<=[\s(\[{])(?:vector-store/create|vector-store/open|vector-store/save|vector-store/add|vector-store/search|vector-store/count|vector-store/delete)(?=[\s)\]}]|$)'
      scope: support.function.sema
    # Tool query functions
    - match: '(?<=[\s(\[{])(?:tool/name|tool/description|tool/parameters)(?=[\s)\]}]|$)'
      scope: support.function.sema
    # async builtins
    - match: '(?<=[\s(\[{])(?:async/all|async/await|async/cancel|async/cancelled\?|async/forced\?|async/map|async/pending\?|async/pool-map|async/promise\?|async/race|async/rejected|async/rejected\?|async/resolved|async/resolved\?|async/run|async/sleep|async/spawn|async/spawn-all|async/timeout)(?=[\s)\]}]|$)'
      scope: support.function.sema
    # channel builtins
    - match: '(?<=[\s(\[{])(?:channel/close|channel/closed\?|channel/count|channel/empty\?|channel/full\?|channel/new|channel/recv|channel/send|channel/try-recv)(?=[\s)\]}]|$)'
      scope: support.function.sema
    # conversation builtins
    - match: '(?<=[\s(\[{])(?:conversation/find|conversation/insert|conversation/length|conversation/map-role|conversation/models-used|conversation/remove|conversation/replace|conversation/search|conversation/stats|conversation/turns)(?=[\s)\]}]|$)'
      scope: support.function.sema
    # db builtins
    - match: '(?<=[\s(\[{])(?:db/close|db/exec|db/query)(?=[\s)\]}]|$)'
      scope: support.function.sema
    # f64-array builtins
    - match: '(?<=[\s(\[{])(?:f64-array|f64-array\?|f64-array/dot|f64-array/fold|f64-array/from-list|f64-array/length|f64-array/make|f64-array/map|f64-array/range|f64-array/ref|f64-array/set!|f64-array/sum)(?=[\s)\]}]|$)'
      scope: support.function.sema
    # i64-array builtins
    - match: '(?<=[\s(\[{])(?:i64-array|i64-array\?|i64-array/fold|i64-array/from-list|i64-array/length|i64-array/make|i64-array/map|i64-array/range|i64-array/ref|i64-array/set!|i64-array/sum)(?=[\s)\]}]|$)'
      scope: support.function.sema
    # io builtins
    - match: '(?<=[\s(\[{])(?:io/eof\?|io/flush|io/read-key|io/read-key-timeout|io/tty-raw!|io/tty-restore!|io/with-raw-mode)(?=[\s)\]}]|$)'
      scope: support.function.sema
    # additional list builtins
    - match: '(?<=[\s(\[{])(?:list/contains\?|list/drop-last|list/nth-or|list/take-last)(?=[\s)\]}]|$)'
      scope: support.function.sema
    # additional llm builtins
    - match: '(?<=[\s(\[{])(?:llm/cassette-eject|llm/cassette-load|llm/cassette-save|llm/io-sleep-once|llm/rerank|llm/with-cassette)(?=[\s)\]}]|$)'
      scope: support.function.sema
    # additional math builtins
    - match: '(?<=[\s(\[{])(?:math/format-fixed|math/round-to)(?=[\s)\]}]|$)'
      scope: support.function.sema
    # misc builtins
    - match: '(?<=[\s(\[{])(?:channel\?|stream\?|tools->routes)(?=[\s)\]}]|$)'
      scope: support.function.sema
    # otel builtins
    - match: '(?<=[\s(\[{])(?:otel/configure|otel/event|otel/llm-span|otel/llm-usage|otel/retrieval-span|otel/set-attribute|otel/set-attributes|otel/set-status|otel/span|otel/tool-span|otel/with-session)(?=[\s)\]}]|$)'
      scope: support.function.sema
    # pio builtins
    - match: '(?<=[\s(\[{])(?:pio/assemble|pio/delay|pio/in|pio/irq|pio/jmp|pio/mov|pio/nop|pio/out|pio/pull|pio/push|pio/set|pio/side|pio/wait)(?=[\s)\]}]|$)'
      scope: support.function.sema
    # prompt builtins
    - match: '(?<=[\s(\[{])(?:prompt/diff|prompt/difference|prompt/intersection|prompt/union)(?=[\s)\]}]|$)'
      scope: support.function.sema
    # route builtins
    - match: '(?<=[\s(\[{])(?:route/prefix)(?=[\s)\]}]|$)'
      scope: support.function.sema
    # stream builtins
    - match: '(?<=[\s(\[{])(?:stream/available\?|stream/byte-buffer|stream/close|stream/copy|stream/flush|stream/from-bytes|stream/from-string|stream/read|stream/read-all|stream/read-byte|stream/read-line|stream/readable\?|stream/to-bytes|stream/to-string|stream/type|stream/writable\?|stream/write|stream/write-byte|stream/write-string)(?=[\s)\]}]|$)'
      scope: support.function.sema
    # additional string builtins
    - match: '(?<=[\s(\[{])(?:string/lines|string/width|string/word-wrap)(?=[\s)\]}]|$)'
      scope: support.function.sema
    # additional sys builtins
    - match: '(?<=[\s(\[{])(?:sys/term-size|sys/config-dir)(?=[\s)\]}]|$)'
      scope: support.function.sema
    # additional time builtins
    - match: '(?<=[\s(\[{])(?:time/ms|time/now-ms|time/tick)(?=[\s)\]}]|$)'
      scope: support.function.sema
    # workflow builtins
    - match: '(?<=[\s(\[{])(?:settled/err\?|settled/ok\?|checkpoint|parallel|parallel-settled|phase|pipeline|pipeline-settled|settled-partition|step|workflow/check|workflow/checkpoint|workflow/phase|workflow/run|workflow/run-form|workflow/step|workflow/tool-call)(?=[\s)\]}]|$)'
      scope: support.function.sema
    # diff builtins
    - match: '(?<=[\s(\[{])(?:diff/apply|diff/hunks|diff/parse|diff/stat|diff/unified)(?=[\s)\]}]|$)'
      scope: support.function.sema
    # event builtins
    - match: '(?<=[\s(\[{])(?:event/select)(?=[\s)\]}]|$)'
      scope: support.function.sema
    # format builtins
    - match: '(?<=[\s(\[{])(?:format/form)(?=[\s)\]}]|$)'
      scope: support.function.sema
    # fs builtins
